# Nginx Dockerfile for emotion-ai
# 这个Dockerfile会在构建时自动包含最新的dist目录内容

FROM nginx:alpine

# 删除默认配置
RUN rm /etc/nginx/conf.d/default.conf

# 复制nginx配置
COPY frontend/web/nginx.conf /etc/nginx/conf.d/default.conf

# 复制前端构建产物（构建时会自动包含最新代码）
# v2.1 - force rebuild with new dist
COPY frontend/web/dist/ /usr/share/nginx/html/

# 复制Live2D模型文件
COPY frontend/web/public/live2d/ /usr/share/nginx/html/live2d/

# 创建日志目录
RUN mkdir -p /var/log/nginx

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]