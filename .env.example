# AI情感助手生产环境配置文件
# 复制此文件为 .env 并修改配置

# ==============================================
# 基础配置
# ==============================================
# 时区
TZ=Asia/Shanghai

# 服务端口配置
HTTP_PORT=80
HTTPS_PORT=443

# ==============================================
# 数据库配置
# ==============================================
# MySQL根密码（生产环境必须修改为强密码）
MYSQL_ROOT_PASSWORD=your_strong_root_password_here
# 数据库名称
MYSQL_DATABASE=emotion_ai
# 数据库用户名
MYSQL_USER=emotion_ai
# 数据库密码（生产环境必须修改为强密码）
MYSQL_PASSWORD=your_strong_mysql_password_here

# ==============================================
# Redis配置
# ==============================================
# Redis密码（生产环境必须修改为强密码）
REDIS_PASSWORD=your_strong_redis_password_here

# ==============================================
# 后端配置
# ==============================================
# 应用密钥（生产环境必须修改为32位随机字符串）
SECRET_KEY=your_32_character_secret_key_here
# 后端工作进程数
BACKEND_WORKERS=4
# LLM提供商（mock/openai/baidu/aliyun等）
LLM_PROVIDER=mock
# LLM API密钥
LLM_API_KEY=your_llm_api_key_here
# LLM API基础URL
LLM_BASE_URL=https://api.example.com/v1

# ==============================================
# 前端配置
# ==============================================
# API基础URL
VITE_API_BASE_URL=/api

# ==============================================
# 监控配置
# ==============================================
# Grafana管理员密码（生产环境必须修改为强密码）
GRAFANA_PASSWORD=your_strong_grafana_password_here

# ==============================================
# 备份配置
# ==============================================
# 备份保留天数
BACKUP_RETENTION_DAYS=7
# 备份目录
BACKUP_DIR=./deploy/backup
# 备份时间（cron格式）
BACKUP_CRON=0 2 * * *

# ==============================================
# SSL配置
# ==============================================
# 域名
DOMAIN=your-domain.com
# SSL证书邮箱（用于Let's Encrypt）
SSL_EMAIL=your-email@example.com
