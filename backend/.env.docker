# ============================================
# 后端 Docker 环境变量配置
# 复制为 .env.docker 并修改
# ============================================

# 应用配置
APP_NAME=心灵伴侣AI
APP_VERSION=1.0.0
DEBUG=false

# 服务器
HOST=0.0.0.0
PORT=8000

# 数据库 (由 docker-compose 注入 MYSQL_HOST)
MYSQL_PORT=3306
MYSQL_USER=emotion_ai
MYSQL_PASSWORD=emotion_ai_password_2024!Secure
MYSQL_DATABASE=emotion_ai
DATABASE_URL=mysql+mysqlconnector://emotion_ai:emotion_ai_password_2024!Secure@mysql:3306/emotion_ai?charset=utf8mb4

# Redis (由 docker-compose 注入 REDIS_HOST)
REDIS_PORT=6379
REDIS_DB=0

# JWT
SECRET_KEY=your-32-char-min-secret-key-change-in-prod-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# 大模型
LLM_PROVIDER=mock

# 向量数据库
# 向量数据库
VECTOR_DB_TYPE=milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=emotion_knowledge

# Embedding配置
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# CORS
CORS_ORIGINS=["http://localhost","http://localhost:80","http://your-domain.com"]
