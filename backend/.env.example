# 应用配置
APP_NAME=心灵伴侣AI
APP_VERSION=1.0.0
DEBUG=true

# 服务器
HOST=0.0.0.0
PORT=8000

# 数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=emotion_ai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# 大模型配置
LLM_PROVIDER=mock

# OpenAI (可选)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# Anthropic (可选)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# 智谱GLM (可选)
GLM_API_KEY=
GLM_MODEL=glm-4

# 阿里通义千问 (可选)
QWEN_API_KEY=
QWEN_MODEL=qwen-turbo

# MiniMax (可选)
MINIMAX_API_KEY=
MINIMAX_MODEL=abab5.5-chat

# 向量数据库
VECTOR_DB_TYPE=milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=emotion_knowledge

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=emotion_knowledge

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# 微信支付 (可选)
WECHAT_PAY_ENABLED=false
WECHAT_MCHID=your_mchid
WECHAT_SERIAL_NO=your_serial_no
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_APIV3_KEY=your_apiv3_key
WECHAT_APPID=your_appid
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/wechat/notify

# 支付宝支付 (可选)
ALIPAY_ENABLED=false
ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY_PATH=./certs/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=./certs/alipay_public_key.pem
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.com/payment/success

# Stripe支付 (可选)
STRIPE_API_KEY=your_stripe_api_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# API基础URL (用于支付回调)
API_BASE_URL=https://your-domain.com

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]